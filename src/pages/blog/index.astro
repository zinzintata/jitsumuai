---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const url = Astro.url;
const categoryFilter = url.searchParams.get('category');

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const filteredPosts = categoryFilter
  ? allPosts.filter(p => p.data.category === categoryFilter)
  : allPosts;

const categories = [...new Set(allPosts.map(p => p.data.category))];

const categoryMeta: Record<string, { icon: string; color: string }> = {
  'AI活用':       { icon: '💼', color: 'text-blue-600 bg-blue-50 border-blue-200' },
  'AIエージェント': { icon: '🤖', color: 'text-violet-600 bg-violet-50 border-violet-200' },
  '製造業DX':     { icon: '🏭', color: 'text-orange-600 bg-orange-50 border-orange-200' },
  '転職・キャリア': { icon: '📈', color: 'text-emerald-600 bg-emerald-50 border-emerald-200' },
};
---

<BaseLayout
  title={categoryFilter ? `${categoryFilter}の記事一覧` : '記事一覧'}
  description="製造業・事務職のAI活用に関する実践的な記事を掲載しています。"
>
  <Header />

  <!-- ページヘッダー -->
  <div class="bg-gradient-to-b from-slate-900 to-slate-800 text-white py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-semibold text-blue-400 uppercase tracking-widest mb-2">Articles</p>
      <h1 class="text-2xl sm:text-3xl font-bold text-white" style="font-family: 'Noto Serif JP', serif;">
        {categoryFilter ?? '記事一覧'}
      </h1>
      <p class="text-slate-400 text-sm mt-2">{filteredPosts.length}件の記事</p>
    </div>
  </div>

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <!-- カテゴリフィルター -->
    <div class="flex flex-wrap gap-2 mb-8">
      <a
        href="/blog/"
        class:list={[
          'inline-flex items-center gap-1.5 text-sm font-medium px-4 py-2 rounded-full border-2 transition-all duration-200',
          !categoryFilter
            ? 'border-blue-600 bg-blue-600 text-white'
            : 'border-slate-200 text-slate-600 hover:border-blue-300 hover:text-blue-600 bg-white',
        ]}
      >
        すべて
        <span class="text-xs opacity-70">({allPosts.length})</span>
      </a>
      {categories.map(cat => {
        const meta = categoryMeta[cat] ?? { icon: '', color: 'text-slate-600 bg-white border-slate-200' };
        const count = allPosts.filter(p => p.data.category === cat).length;
        return (
          <a
            href={`/blog/?category=${encodeURIComponent(cat)}`}
            class:list={[
              'inline-flex items-center gap-1.5 text-sm font-medium px-4 py-2 rounded-full border-2 transition-all duration-200',
              categoryFilter === cat
                ? 'border-blue-600 bg-blue-600 text-white'
                : `${meta.color} hover:border-blue-300 bg-white`,
            ]}
          >
            {meta.icon} {cat}
            <span class="text-xs opacity-70">({count})</span>
          </a>
        );
      })}
    </div>

    <!-- 記事グリッド -->
    {filteredPosts.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {filteredPosts.map((post, i) => (
          <div data-animate data-animate-delay={String((i % 3) + 1)}>
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              slug={post.slug}
              pubDate={post.data.pubDate}
              category={post.data.category}
              tags={post.data.tags}
            />
          </div>
        ))}
      </div>
    ) : (
      <div class="text-center py-20 text-slate-400">
        <p class="text-4xl mb-4">📭</p>
        <p>この条件に一致する記事はまだありません。</p>
      </div>
    )}
  </main>

  <Footer />
</BaseLayout>
