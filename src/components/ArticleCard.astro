---
interface Props {
  title: string;
  description: string;
  slug: string;
  pubDate: Date;
  category: string;
  tags?: string[];
  featured?: boolean;
  image?: string;
}
const { title, description, slug, pubDate, category, tags = [], featured = false, image } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('ja-JP', {
  year: 'numeric', month: 'long', day: 'numeric',
});

const categoryMap: Record<string, { bg: string; text: string; dot: string }> = {
  'AI活用':       { bg: 'bg-blue-50',   text: 'text-blue-700',  dot: 'bg-blue-500' },
  'AIエージェント': { bg: 'bg-violet-50', text: 'text-violet-700', dot: 'bg-violet-500' },
  '製造業DX':     { bg: 'bg-orange-50', text: 'text-orange-700', dot: 'bg-orange-500' },
  '転職・キャリア': { bg: 'bg-emerald-50',text: 'text-emerald-700',dot: 'bg-emerald-500' },
};
const cat = categoryMap[category] ?? { bg: 'bg-slate-50', text: 'text-slate-600', dot: 'bg-slate-400' };
---

<article
  class:list={[
    'group bg-white rounded-xl border border-slate-200 overflow-hidden',
    'transition-all duration-300 hover:-translate-y-1',
    'hover:shadow-[0_8px_24px_rgba(37,99,235,0.10),0_2px_8px_rgba(0,0,0,0.06)]',
    'hover:border-blue-200',
    featured && 'sm:col-span-2',
  ]}
>
  <!-- アイキャッチ画像 or カテゴリカラーバー -->
  {image ? (
    <div class="relative overflow-hidden" style="height: 160px;">
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
    </div>
  ) : (
    <div class:list={['h-1 w-full', cat.dot.replace('bg-', 'bg-')]}></div>
  )}

  <a href={`/blog/${slug}/`} class="block p-5 h-full">
    <div class="flex items-center gap-2 mb-3">
      <span class:list={['inline-flex items-center gap-1.5 text-xs font-semibold px-2.5 py-1 rounded-full', cat.bg, cat.text]}>
        <span class:list={['w-1.5 h-1.5 rounded-full', cat.dot]}></span>
        {category}
      </span>
      <time class="text-xs text-slate-400" datetime={pubDate.toISOString()}>
        {formattedDate}
      </time>
    </div>

    <h2 class:list={[
      'font-bold text-slate-900 leading-snug mb-2',
      'group-hover:text-blue-700 transition-colors duration-200',
      featured ? 'text-xl' : 'text-base',
      'line-clamp-2',
    ]}>
      {title}
    </h2>

    <p class="text-sm text-slate-500 leading-relaxed line-clamp-2 mb-3">
      {description}
    </p>

    <div class="flex items-center justify-between mt-auto pt-2">
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-1">
          {tags.slice(0, 2).map(tag => (
            <span class="text-xs text-slate-400 bg-slate-50 border border-slate-100 px-2 py-0.5 rounded-md">
              #{tag}
            </span>
          ))}
        </div>
      )}
      <span class="ml-auto text-xs font-medium text-blue-600 group-hover:translate-x-1 transition-transform duration-200">
        読む →
      </span>
    </div>
  </a>
</article>
