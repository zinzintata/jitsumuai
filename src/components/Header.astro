---
const navLinks = [
  { href: '/', label: 'ホーム' },
  { href: '/blog/', label: '記事一覧' },
  { href: '/about/', label: '運営者紹介' },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-50">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14">
      <a href="/" class="flex items-center gap-2 group">
        <span class="text-lg font-bold text-blue-600 group-hover:text-blue-700 transition-colors">
          jitsumuai.com
        </span>
        <span class="hidden sm:block text-xs text-gray-500 border-l border-gray-300 pl-2">
          製造業・事務職のAI活用メディア
        </span>
      </a>
      <nav class="flex items-center gap-1">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              'px-3 py-1.5 text-sm rounded-md transition-colors',
              currentPath === href || (href !== '/' && currentPath.startsWith(href))
                ? 'bg-blue-50 text-blue-700 font-medium'
                : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100',
            ]}
          >
            {label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</header>
